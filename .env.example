# ── Telegram ──────────────────────────────────────────────────────────────────
# Token del Bot A (obtenido de @BotFather)
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Secret token para validar que los requests vienen de Telegram
# Generá uno aleatorio: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=your-secret-token-here

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Google Sheets ─────────────────────────────────────────────────────────────
# JSON del Service Account en base64
# Para codificarlo: python scripts/encode_credentials.py ruta/al/credentials.json
GOOGLE_CREDENTIALS_JSON=base64-encoded-service-account-json

# ID de la Google Sheet (está en la URL: /spreadsheets/d/[ESTE_ID]/edit)
GOOGLE_SPREADSHEET_ID=your-spreadsheet-id-here

# ── Upstash Redis ─────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token-here

# ── Configuración del bot ─────────────────────────────────────────────────────
# ICP editable sin tocar código
ICP_DEFINITION=Empresa de servicios o consultoría B2B, con mínimo 5 empleados, ubicada en España o Latinoamérica, con interés declarado o implícito en automatización de procesos o inteligencia artificial.

# Máximo de mensajes por minuto por usuario antes de activar anti-spam
RATE_LIMIT_PER_MINUTE=5
